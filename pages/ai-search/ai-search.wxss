/* pages/ai-search/ai-search.wxss */

/* 头部 */
.header {
  text-align: center;
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: -20rpx -30rpx 30rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 初始状态 */
.idle-section {
  padding: 20rpx 0;
}

.upload-area {
  background: #f8f9fa;
  border: 4rpx dashed #ddd;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  margin-bottom: 40rpx;
}

.upload-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.upload-text {
  display: block;
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.upload-subtext {
  display: block;
  font-size: 28rpx;
  color: #999;
}

/* 按钮 */
.action-buttons {
  display: flex;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.btn-primary {
  flex: 1;
  background: #667eea;
  color: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-secondary {
  flex: 1;
  background: #f0f0f0;
  color: #333;
  padding: 30rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 32rpx;
}

/* 提示 */
.tips-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.tips-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-item {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 历史记录 */
.history-section {
  margin-top: 40rpx;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.history-scroll {
  white-space: nowrap;
}

.history-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.history-thumb {
  width: 100%;
  height: 150rpx;
}

.history-text {
  display: block;
  padding: 16rpx;
  font-size: 24rpx;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 预览状态 */
.preview-section {
  padding: 20rpx 0;
}

.preview-image {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.preview-actions {
  display: flex;
  gap: 24rpx;
}

/* 分析中状态 */
.analyzing-section {
  padding: 60rpx 30rpx;
  text-align: center;
}

.analyzing-image {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
  opacity: 0.6;
}

.analyzing-animation {
  padding: 40rpx;
}

.ai-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.analyzing-text {
  display: block;
  font-size: 36rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 30rpx;
}

.progress-bar {
  width: 80%;
  height: 12rpx;
  background: #eee;
  border-radius: 6rpx;
  margin: 0 auto 20rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  width: 30%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 6rpx;
  animation: progress 3s ease-in-out infinite;
}

@keyframes progress {
  0% { width: 0%; }
  50% { width: 70%; }
  100% { width: 100%; }
}

.analyzing-subtext {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 结果状态 */
.result-section {
  padding: 20rpx 0 40rpx;
}

.result-image-wrapper {
  margin-bottom: 30rpx;
}

.result-image {
  width: 100%;
  border-radius: 16rpx;
}

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.result-card.highlight {
  border-left: 8rpx solid #52c41a;
  background: #f6ffed;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.question-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

.answer-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #52c41a;
}

.analysis-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

.knowledge-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.knowledge-tag {
  padding: 12rpx 24rpx;
  background: #f0f0f0;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 40rpx;
}

/* 错误状态 */
.error-section {
  text-align: center;
  padding: 80rpx 40rpx;
}

.error-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.error-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.error-message {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.error-tips {
  text-align: left;
  background: #fff2f0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.error-tips text {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.error-tips text:first-child {
  font-weight: 600;
  color: #333;
}