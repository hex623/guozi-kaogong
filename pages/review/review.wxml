<!-- pages/review/review.wxml -->
<view class="container">
  <!-- 今日待复习统计 -->
  <view class="header-card">
    <view class="header-content">
      <view class="review-count">
        <text class="count-number">{{todayList.length}}</text>
        <text class="count-label">今日待复习</text>
      </view>
      
      <view class="review-progress" wx:if="{{todayList.length > 0}}">
        <text class="progress-text">已完成 {{completedCount}}/{{todayList.length}}</text>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{(completedCount/todayList.length)*100}}%"></view>
        </view>
      </view>
    </view>
    
    <!-- 模式切换和重点题按钮 -->
    <view class="header-actions" wx:if="{{todayList.length > 0}}">
      <view class="mode-switch" bindtap="switchReviewMode">
        <text class="mode-text">{{reviewMode === 'quick' ? '⚡ 快速模式' : '📚 正常模式'}}</text>
        <text class="mode-arrow">▸</text>
      </view>
      <view class="fav-filter" bindtap="showFavoritesOnly">
        <text class="fav-icon">⭐</text>
        <text class="fav-text">重点题</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{todayList.length === 0 && !loading}}" class="empty-state">
    <view class="empty-icon">🎉</view>
    <text class="empty-title">今日复习已完成</text>
    <text class="empty-desc">基于艾宾浩斯遗忘曲线，新错题将在第1/2/4/7/15天自动推送</text>
    
    <button class="btn-secondary" bindtap="goToAdd">去录入新错题</button>
  </view>

  <!-- 当前复习题目 -->
  <view wx:if="{{currentQuestion && !showResult}}" class="review-card">
    <!-- 题目信息 -->
    <view class="question-header">
      <view class="question-meta">
        <text class="review-stage">第{{currentQuestion.reviewCount + 1}}次复习</text>
        <text class="question-source" wx:if="{{currentQuestion.source}}">{{currentQuestion.source}}</text>
        <!-- 重点标记按钮 -->
        <view class="favorite-btn {{currentQuestion.isFavorite ? 'active' : ''}}" bindtap="toggleFavorite">
          <text>{{currentQuestion.isFavorite ? '⭐' : '☆'}}</text>
        </view>
      </view>
      
      <view class="question-tags" wx:if="{{currentQuestion.tags.length > 0}}">
        <text wx:for="{{currentQuestion.tags}}" wx:key="*this" class="tag">{{item}}</text>
      </view>
    </view>

    <!-- 题目照片 -->
    <view class="question-images">
      <image wx:for="{{currentQuestion.photos}}" wx:key="*this"
             src="{{item}}" mode="widthFix" 
             bindtap="previewImage"
             data-url="{{item}}"/>
    </view>

    <!-- 错误答案提示 -->
    <view wx:if="{{currentQuestion.wrongAnswer}}" class="wrong-answer-hint">
      <text class="hint-label">❌ 上次错选</text>
      <text class="hint-content">{{currentQuestion.wrongAnswer}}</text>
    </view>

    <!-- 快速模式：直接显示掌握程度选择（不看答案） -->
    <view wx:if="{{reviewMode === 'quick' && !showAnswer}}" class="quick-mastery-section">
      <text class="quick-title">快速评估掌握程度</text>
      <view class="mastery-grid">
        <view wx:for="{{masteryLevels}}" wx:key="level" 
              class="mastery-item"
              style="border-color: {{item.color}}"
              bindtap="quickMark"
              data-level="{{item.level}}">
          <text class="mastery-icon">{{item.icon}}</text>
          <text class="mastery-label">{{item.label}}</text>
          <text class="mastery-desc">{{item.desc}}</text>
        </view>
      </view>
      
      <view class="quick-actions">
        <button class="btn-secondary btn-small" bindtap="showAnswer">查看答案</button>
      </view>
    </view>

    <!-- 正常模式：查看答案按钮 -->
    <view class="action-area" wx:if="{{reviewMode === 'normal' && !showAnswer}}">
      <button class="btn-primary btn-large" bindtap="showAnswer">
        查看答案
      </button>
    </view>

    <!-- 答案区域 -->
    <view wx:if="{{showAnswer}}" class="answer-section">
      <view class="answer-label">✅ 正确答案</view>
      
      <view wx:if="{{currentQuestion.answerType === 'text'}}" class="answer-text">
        {{currentQuestion.correctAnswer}}
      </view>
      
      <image wx:if="{{currentQuestion.answerType === 'image' && currentQuestion.correctAnswerImage}}"
             src="{{currentQuestion.correctAnswerImage}}" 
             mode="widthFix"
             class="answer-image"
             bindtap="previewAnswerImage"/>

      <!-- 多级别掌握程度选择 -->
      <view class="mastery-section">
        <text class="mastery-title">掌握程度如何？</text>
        
        <view class="mastery-list">
          <view wx:for="{{masteryLevels}}" wx:key="level"
                class="mastery-btn"
                style="background: {{item.color}}"
                bindtap="markMasteryLevel"
                data-level="{{item.level}}">
            <text class="btn-icon">{{item.icon}}</text>
            <view class="btn-content">
              <text class="btn-label">{{item.label}}</text>
              <text class="btn-desc">{{item.desc}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 完成状态 -->
  <view wx:if="{{showResult}}" class="result-card">
    <view class="result-icon">{{resultIcon}}</view>
    <text class="result-title">{{resultTitle}}</text>
    <text class="result-desc">{{resultDesc}}</text>
    
    <view class="next-review-info" wx:if="{{nextReviewDate}}">
      <text>下次复习：{{nextReviewDate}}</text>
    </view>
    
    <button class="btn-primary" bindtap="nextQuestion">
      {{currentIndex < todayList.length - 1 ? '下一题' : '完成复习'}}
    </button>
  </view>
</view>